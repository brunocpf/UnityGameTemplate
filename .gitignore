# This .gitignore targets Unity projects.
# Keep source assets in Git, ignore generated/editor-specific files.

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/
UserSettings/

# Addressables / generated content
Assets/AddressableAssetsData/*/*.bin*

# Auto-generated solution and project files (regenerated by Unity).
# NOTE: .slnx is the canonical, hand-maintained solution file — DO NOT ignore it.
*.csproj
*.sln
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.suo
*.tmp
*.userosscache
*.sln.docstates

# Unity crash reports
sysinfo.txt

# Visual Studio / Rider / JetBrains
.vs/
.idea/
*.swp

# VS Code (ignore workspace-local noise; keep shared config)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# OS-specific files
.DS_Store
.AppleDouble
.LSOverride
Icon
Thumbs.db
._*
.Spotlight-V100
.Trashes

# Package manager cache folders (if present)
node_modules/

# Backup files
*.bak
*.backup
*.old
*.orig

# Generated test results
TestResults/

# NuGet for Unity restored packages
Assets/Packages/
Assets/Packages.meta

# Auto-generated UIElements files
UIElementsSchema/

# Personal Claude settings (per-developer overrides)
.claude/settings.local.json

# Bootstrap sentinel — set after running ./bootstrap.sh
.bootstrapped
